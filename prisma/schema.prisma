generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WorkdayOpen {
  employeeId String   @id
  startTime  DateTime
  createdAt  DateTime @default(now())

  @@map("workday_open")
}

model WorkdayHistory {
  id              String              @id @default(uuid())
  employeeId      String
  startTime       DateTime
  endTime         DateTime?
  workedMinutes   Int
  expectedMinutes Int
  deltaMinutes    Int
  createdAt       DateTime            @default(now())
  earlyLeave      Boolean
  lateArrival     Boolean
  periodId        String
  adjustments     WorkdayAdjustment[]
  period          WorkPeriod          @relation(fields: [periodId], references: [id])

  @@map("workday_history")
}

model WorkdayRules {
  id          String         @id @default(uuid())
  baseMinutes Int
  createdAt   DateTime       @default(now())
  breaks      WorkdayBreak[]
}

model WorkdayBreak {
  id      String       @id @default(uuid())
  rulesId String
  start   String
  end     String
  rules   WorkdayRules @relation(fields: [rulesId], references: [id])
}

model WorkdayAdjustment {
  id         String         @id @default(uuid())
  historyId  String
  type       String
  minutes    Int
  reason     String
  approvedBy String
  createdAt  DateTime       @default(now())
  history    WorkdayHistory @relation(fields: [historyId], references: [id])

  @@map("workday_adjustment")
}

model WorkPeriod {
  id        String           @id @default(uuid())
  year      Int
  month     Int
  half      Int
  startDate DateTime
  endDate   DateTime
  closedAt  DateTime?
  closedBy  String?
  histories WorkdayHistory[]

  @@unique([year, month, half])
}

model User {
  id                  String                       @id @default(uuid())
  active              Boolean                      @default(true)
  createdAt           DateTime                     @default(now())
  passwordHash        String
  role                String
  document            String                       @unique
  pinHash             String?
  email               String?
  firstName           String?
  lastName            String?
  phone               String?
  pinLockedUntil      DateTime?
  failedPinAttempts   Int                          @default(0)
  mustChangePassword  Boolean                      @default(true)
  profileCompleted    Boolean                      @default(false)
  mustChangePin       Boolean                      @default(false)
  scheduleAssignments EmployeeScheduleAssignment[]

  @@map("users")
}

model AdminCase {
  id             String           @id @default(uuid())
  employeeId     String
  type           AdminCaseType
  status         AdminCaseStatus  @default(PENDING)
  reasonCode     String?
  notes          String?
  createdBy      String
  createdAt      DateTime         @default(now())
  appliedBy      String?
  cancelledBy    String?
  cancelledAt    DateTime?
  cancelReason   String?
  appliedAt      DateTime?
  rejectedAt     DateTime?
  rejectedBy     String?
  rejectedReason String?
  scopes         AdminCaseScope[]
  attachments    AdminCaseAttachment[]

  @@index([employeeId])
  @@index([status])
  @@map("admin_case")
}

model AdminCaseScope {
  id               String    @id @default(uuid())
  adminCaseId      String
  date             DateTime
  startMinute      Int?
  endMinute        Int?
  workdayHistoryId String?
  createdAt        DateTime  @default(now())
  adminCase        AdminCase @relation(fields: [adminCaseId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([adminCaseId, date])
  @@map("admin_case_scope")
}

model AuditEvent {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  action      String
  performedBy String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedBy])
}

model ScheduleTemplate {
  id          String                       @id @default(uuid())
  name        String
  createdAt   DateTime                     @default(now())
  assignments EmployeeScheduleAssignment[]
  days        ScheduleTemplateDay[]
}

model ScheduleTemplateDay {
  id                 String           @id @default(uuid())
  scheduleTemplateId String
  weekday            Int
  startMinute        Int
  endMinute          Int
  template           ScheduleTemplate @relation(fields: [scheduleTemplateId], references: [id])

  @@unique([scheduleTemplateId, weekday])
}

model EmployeeScheduleAssignment {
  id                 String           @id @default(uuid())
  employeeId         String
  scheduleTemplateId String
  effectiveFrom      DateTime
  effectiveTo        DateTime?
  employee           User             @relation(fields: [employeeId], references: [id])
  template           ScheduleTemplate @relation(fields: [scheduleTemplateId], references: [id])

  @@index([employeeId, effectiveFrom])
}

enum UserRole {
  EMPLOYEE
  ADMIN
}

enum AdminCaseType {
  INCAPACITY
  PERMISSION
  JUSTIFICATION
  ABSENCE
}

enum AdminCaseStatus {
  PENDING
  APPLIED
  REJECTED
  CANCELLED
}

model AdminCaseAttachment {
  id           String    @id @default(uuid())
  adminCaseId  String
  adminCase    AdminCase @relation(fields: [adminCaseId], references: [id], onDelete: Cascade)
  url          String
  publicId     String
  resourceType String
  format       String?
  bytes        Int?
  originalName String?
  createdAt    DateTime  @default(now())

  @@index([adminCaseId])
  @@map("admin_case_attachment")
}